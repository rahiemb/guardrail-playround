{
  "name": "guardrail-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"UI,ENGINE\" --prefix-colors \"cyan,yellow\" \"pnpm --filter ui dev\" \"pnpm --filter ui exec -- sh -c 'cd ../../packages/engine && python -m uvicorn guardrail_engine.main:app --reload --port 8000'\"",
    "dev:ui": "pnpm --filter ui dev",
    "dev:engine": "cd packages/engine && python -m uvicorn guardrail_engine.main:app --reload --port 8000",
    "build": "pnpm --filter ui build",
    "lint": "pnpm --filter ui lint",
    "typecheck": "pnpm --filter ui typecheck",
    "test:ui": "pnpm --filter ui test",
    "test:engine": "cd packages/engine && python -m pytest"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
